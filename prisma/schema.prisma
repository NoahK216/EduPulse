generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["neon_auth", "public"]
}

model user_profile {
  id        String @id @db.Uuid
  auth_user user   @relation("auth_to_profile", fields: [id], references: [id], onDelete: Cascade)

  created_assignments assignment[]       @relation("assignment_creator")
  attempts            attempt[]
  classroom_members   classroom_member[]
  created_classrooms  classroom[]        @relation("classroom_creator")
  published_versions  scenario_version[] @relation("scenario_publisher")
  scenarios           scenario[]         @relation("scenario_owner")

  @@schema("public")
}

model classroom {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by_id String             @db.Uuid
  name          String             @db.VarChar(255)
  code          String?            @unique @db.VarChar(64)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  updated_at    DateTime           @default(now()) @db.Timestamptz(6)
  assignments   assignment[]
  members       classroom_member[]
  created_by    user_profile       @relation("classroom_creator", fields: [created_by_id], references: [id], onUpdate: NoAction)

  @@index([created_by_id])
  @@schema("public")
}

model classroom_member {
  classroom_id String         @db.Uuid
  user_id      String         @db.Uuid
  role         classroom_role
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  classroom    classroom      @relation(fields: [classroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         user_profile   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([classroom_id, user_id])
  @@index([user_id])
  @@index([classroom_id, role])
  @@schema("public")
}

model scenario {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id         String             @db.Uuid
  title                 String             @db.VarChar(255)
  description           String?
  draft_content         Json?
  latest_version_number Int                @default(0)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  updated_at            DateTime           @default(now()) @db.Timestamptz(6)
  versions              scenario_version[]
  owner                 user_profile       @relation("scenario_owner", fields: [owner_user_id], onDelete: Cascade, references: [id], onUpdate: NoAction)

  @@index([owner_user_id])
  @@schema("public")
}

model scenario_version {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenario_id          String       @db.Uuid
  version_number       Int
  title                String       @db.VarChar(255)
  content              Json
  published_by_user_id String       @db.Uuid
  published_at         DateTime     @default(now()) @db.Timestamptz(6)
  assignments          assignment[]
  published_by         user_profile @relation("scenario_publisher", fields: [published_by_user_id], references: [id], onUpdate: NoAction)
  scenario             scenario     @relation(fields: [scenario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([scenario_id, version_number])
  @@index([published_by_user_id])
  @@schema("public")
}

model assignment {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroom_id        String           @db.Uuid
  scenario_version_id String           @db.Uuid
  assigned_by_user_id String           @db.Uuid
  title               String           @db.VarChar(255)
  instructions        String?
  open_at             DateTime?        @db.Timestamptz(6)
  due_at              DateTime?        @db.Timestamptz(6)
  close_at            DateTime?        @db.Timestamptz(6)
  max_attempts        Int?             @default(1)
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @db.Timestamptz(6)
  assigned_by         user_profile     @relation("assignment_creator", fields: [assigned_by_user_id], references: [id], onUpdate: NoAction)
  classroom           classroom        @relation(fields: [classroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  scenario_version    scenario_version @relation(fields: [scenario_version_id], references: [id], onUpdate: NoAction)
  attempts            attempt[]

  @@index([classroom_id])
  @@index([assigned_by_user_id])
  @@index([due_at])
  @@schema("public")
}

model attempt {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignment_id   String         @db.Uuid
  student_user_id String         @db.Uuid
  attempt_number  Int            @default(1)
  status          attempt_status @default(in_progress)
  current_node_id String?        @db.VarChar(255)
  started_at      DateTime       @default(now()) @db.Timestamptz(6)
  last_activity_at DateTime      @default(now()) @db.Timestamptz(6)
  submitted_at    DateTime?      @db.Timestamptz(6)
  assignment      assignment     @relation(fields: [assignment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student         user_profile   @relation(fields: [student_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responses       response[]

  @@unique([assignment_id, student_user_id, attempt_number])
  @@index([student_user_id])
  @@index([assignment_id, status])
  @@index([submitted_at])
  @@schema("public")
}

model response {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id       String   @db.Uuid
  node_id          String   @db.VarChar(255)
  response_payload Json?
  feedback         String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  attempt          attempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([attempt_id, node_id])
  @@index([created_at])
  @@schema("public")
}

model account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @db.Timestamptz(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@schema("neon_auth")
}

model invitation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  email          String
  role           String?
  status         String
  expiresAt      DateTime     @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  inviterId      String       @db.Uuid
  user           user         @relation(fields: [inviterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email])
  @@index([organizationId])
  @@schema("neon_auth")
}

model jwks {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicKey  String
  privateKey String
  createdAt  DateTime  @db.Timestamptz(6)
  expiresAt  DateTime? @db.Timestamptz(6)

  @@schema("neon_auth")
}

model member {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  role           String
  createdAt      DateTime     @db.Timestamptz(6)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           user         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId])
  @@index([userId])
  @@schema("neon_auth")
}

model organization {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String       @unique
  logo       String?
  createdAt  DateTime     @db.Timestamptz(6)
  metadata   String?
  invitation invitation[]
  member     member[]

  @@schema("neon_auth")
}

model project_config {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  endpoint_id        String   @unique
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  trusted_origins    Json
  social_providers   Json
  email_provider     Json?
  email_and_password Json?
  allow_localhost    Boolean
  plugin_configs     Json?
  webhook_config     Json?

  @@schema("neon_auth")
}

model session {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt            DateTime @db.Timestamptz(6)
  token                String   @unique
  createdAt            DateTime @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime @db.Timestamptz(6)
  ipAddress            String?
  userAgent            String?
  userId               String   @db.Uuid
  impersonatedBy       String?
  activeOrganizationId String?
  user                 user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@schema("neon_auth")
}

model user {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @default(now()) @db.Timestamptz(6)
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?    @db.Timestamptz(6)
  account       account[]
  invitation    invitation[]
  member        member[]
  session       session[]

  userProfiles user_profile[] @relation("auth_to_profile")

  @@schema("neon_auth")
}

model verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([identifier])
  @@schema("neon_auth")
}

enum classroom_role {
  instructor
  student

  @@schema("public")
}

enum attempt_status {
  in_progress
  submitted

  @@schema("public")
}
